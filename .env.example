# انسخي إلى .env محلياً أو أضيفي في Render → Environment
# لا ترفعي .env إلى GitHub

API_KEY=graduation-secret-key
SERVER_URL=https://parental-server-4mms.onrender.com

# Gmail App Password (ليس كلمة مرور الحساب العادية)
SMTP_USER=parent.controll.app@gmail.com
SMTP_PASS=your-gmail-app-password-not-account-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Turso — حفظ دائم على Render (أضيفي في Render → Environment، لا ترفعي القيم إلى GitHub)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Render API — لسكربت الإعداد التلقائي scripts/setup_turso_on_render.ps1 فقط
RENDER_API_KEY=rnd_your_render_api_key
