# انسخي إلى .env محلياً أو أضيفي في Render → Environment
# لا ترفعي .env إلى GitHub

API_KEY=graduation-secret-key
SERVER_URL=https://parental-server-4mms.onrender.com

# === الربط الحقيقي عبر البريد (مطلوب على Render) ===
# Render المجاني يحظر SMTP — استخدمي Resend:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=MYRana <onboarding@resend.dev>

# أو Gmail SMTP (سيرفر مدفوع غير Render):
# SMTP_USER=parent.controll.app@gmail.com
# SMTP_PASS=your-gmail-app-password-not-account-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# 0 = إنتاج: لا يُعاد الرمز في JSON — يجب وصول البريد فعلاً
ALLOW_DEV_FALLBACK=0

# 0 = مشروع التخرج: رمزان حقيقيان من Gmail
SIMPLE_FAMILY_LINK=0

# للتطوير المحلي فقط (بدون بريد):
# ALLOW_DEV_FALLBACK=1
