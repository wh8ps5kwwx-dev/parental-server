<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/child_bg"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/include_child_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_child_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_title"
                    android:textAppearance="@style/ChildText.Section"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/register_subtitle"
                    android:textAppearance="@style/ChildText.Caption"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/stepEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/register_hint_parent_email"
                        android:textAppearance="@style/ChildText.Caption"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/inputParentEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:hint="@string/register_hint_parent_email"
                        android:inputType="textEmailAddress" />

                    <Button
                        android:id="@+id/btnSendCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/btn_register_device" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stepVerify"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/textVerifyHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/child_info_bg"
                        android:padding="12dp"
                        android:text="@string/verify_hint"
                        android:textAppearance="@style/ChildText.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textCodesDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/register_child_code_label"
                        android:textAppearance="@style/ChildText.Section"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/textChildCodeValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_child_code_card"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:padding="18dp"
                        android:textColor="@color/child_primary"
                        android:textIsSelectable="true"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:text="CHILD-A1B2C3D4"
                        tools:visibility="visible" />

                    <Button
                        android:id="@+id/btnCopyChildCode"
                        style="@style/ChildButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/btn_copy_child_code"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <Button
                        android:id="@+id/btnCheckParentLink"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_check_parent_link"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/child_danger"
                    android:textSize="14sp"
                    tools:text="رسالة" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
