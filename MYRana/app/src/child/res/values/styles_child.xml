<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ChildText.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ChildText.Subtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">#CCFFFFFF</item>
    </style>

    <style name="ChildText.Section" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/child_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ChildText.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/child_text_primary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="ChildText.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/child_text_secondary</item>
    </style>

    <style name="ChildButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/child_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ChildButton.Accent" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/child_secondary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ChildButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/child_primary</item>
        <item name="android:textColor">@color/child_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ChildButton.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/child_primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ChildEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_child_input</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/child_text_primary</item>
        <item name="android:textColorHint">@color/child_text_hint</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ChildCard">
        <item name="android:background">@drawable/bg_child_card</item>
        <item name="android:padding">16dp</item>
    </style>
</resources>
