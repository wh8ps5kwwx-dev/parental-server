<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <activity
            android:name=".ui.PermissionsLauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:noHistory="true"
            android:theme="@style/Theme.MYRana.Child">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MonitoringStatusActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.MYRana.Child" />

        <activity
            android:name=".ui.academy.AcademyMenuActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MYRana.Game" />

        <activity
            android:name=".ui.academy.AcademyChallengeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MYRana.Game" />

        <activity
            android:name=".ui.academy.AcademyCityActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MYRana.Game" />

        <activity
            android:name=".ui.academy.AcademyRewardsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MYRana.Game" />

        <activity
            android:name=".ui.GameActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MYRana.Game" />

        <activity
            android:name=".ui.ChildRegistrationActivity"
            android:exported="false"
            android:theme="@style/Theme.MYRana.Child"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.ChildPermissionsActivity"
            android:exported="false"
            android:theme="@style/Theme.MYRana.Child" />

        <activity
            android:name=".ui.BlockWarningActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MYRana" />

        <activity
            android:name=".ui.ScreenTimeWarningActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MYRana" />

        <activity
            android:name=".ui.ScreenTimeLimitActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MYRana" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <service
            android:name=".service.ParentSyncService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".enforcement.ContentFilterAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_content_filter" />
        </service>

        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
