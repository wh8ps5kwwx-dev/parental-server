<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/parent_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/parent_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/parent_chart_daily_usage"
                android:textColor="@color/parent_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.example.myrana.parent.ui.SimpleBarChartView
                android:id="@+id/chartReportsWeekly"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/parent_chart_top_apps"
                android:textColor="@color/parent_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.example.myrana.parent.ui.SimpleBarChartView
                android:id="@+id/chartReportsTopApps"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRequestUsageReport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/parent_btn_request_usage"
        android:textAllCaps="false"
        app:backgroundTint="@color/parent_primary"
        app:cornerRadius="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenScreenTime"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/parent_btn_screen_time"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:strokeColor="@color/parent_primary" />

    <TextView
        android:id="@+id/textReportsMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/parent_text_secondary"
        android:textSize="13sp" />
</LinearLayout>
