<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/parent_bg"
    android:layoutDirection="rtl"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/parentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include
            android:id="@+id/parentHeaderInclude"
            layout="@layout/include_parent_header" />

        <!-- الصفحة الرئيسية — ربط جهاز الطفل (تصميم أمان) -->
        <LinearLayout
            android:id="@+id/stepWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="rtl"
            android:orientation="vertical"
            android:visibility="gone">

            <include layout="@layout/include_parent_welcome_header" />

            <!-- كرت ترحيبي -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_welcome_card"
                android:elevation="3dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="80dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_child_avatar" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/parent_welcome_title"
                            android:textColor="@color/parent_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="4dp"
                            android:text="@string/parent_welcome_purpose"
                            android:textColor="@color/parent_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- كرت خطوات الربط -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_welcome_card"
                android:elevation="3dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/parent_welcome_steps_card_title"
                        android:textColor="@color/parent_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <include
                        layout="@layout/item_welcome_step_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" />

                    <include
                        layout="@layout/item_welcome_step_row_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />

                    <include
                        layout="@layout/item_welcome_step_row_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />

                    <include
                        layout="@layout/item_welcome_step_row_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />

                    <include
                        layout="@layout/item_welcome_step_row_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- كرت معلومات مهمة -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_welcome_card"
                android:elevation="3dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_info_badge"
                            app:tint="@color/parent_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/parent_welcome_info_title"
                            android:textColor="@color/parent_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_info_devices"
                                app:tint="@color/parent_primary" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/parent_welcome_info_devices"
                                android:textColor="@color/parent_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/parent_card_stroke" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_info_multi_child"
                                app:tint="@color/parent_primary" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/parent_welcome_info_multi"
                                android:textColor="@color/parent_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/parent_card_stroke" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_info_approval"
                                app:tint="@color/parent_primary" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/parent_welcome_info_approval"
                                android:textColor="@color/parent_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- زر رئيسي -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartSetup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_parent_btn_gradient"
                android:text="@string/parent_btn_start_setup"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_welcome_link"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/white" />

            <!-- أزرار ثانوية -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewInstructions"
                    style="@style/ParentButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/parent_btn_view_instructions"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_welcome_book"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCheckServerWelcome"
                    style="@style/ParentButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/parent_btn_check_server_short"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_welcome_server"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="18dp" />
            </LinearLayout>

            <!-- حالة السيرفر -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:id="@+id/viewWelcomeServerDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_server_dot_offline" />

                <TextView
                    android:id="@+id/textWelcomeServerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/parent_server_status_unknown"
                    android:textColor="@color/parent_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textWelcomeServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/parent_text_hint"
                android:textIsSelectable="true"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textWelcomeVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:textColor="@color/parent_text_hint"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- خطوة 1: بريد ولي الأمر -->
        <LinearLayout
            android:id="@+id/stepLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/inputGuardianEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/parent_hint_email"
                android:inputType="textEmailAddress" />

            <Spinner
                android:id="@+id/spinnerGuardianRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnSendEmailCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_send_code" />
        </LinearLayout>

        <!-- خطوة 2: رمز البريد -->
        <LinearLayout
            android:id="@+id/stepVerify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/inputEmailCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/parent_hint_email_code"
                android:inputType="number"
                android:maxLength="6" />

            <Button
                android:id="@+id/btnVerifyEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_verify" />
        </LinearLayout>

        <!-- خطوة 3: إضافة الطفل (الاسم) -->
        <LinearLayout
            android:id="@+id/stepAddChild"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/parent_add_child_subtitle"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/inputAddChildName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/parent_hint_child_name" />

            <EditText
                android:id="@+id/inputAddChildAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/parent_hint_child_age"
                android:inputType="number"
                android:maxLength="2" />

            <Button
                android:id="@+id/btnContinueToLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_continue_to_link" />
        </LinearLayout>

        <!-- خطوة 4: ربط جهاز الطفل -->
        <LinearLayout
            android:id="@+id/stepLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/parent_link_subtitle"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/inputChildCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/parent_hint_child_code"
                android:textIsSelectable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/parent_child_code_field_hint"
                android:textColor="#888888"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnPasteChildCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/parent_btn_paste_child_code" />

            <Button
                android:id="@+id/btnCheckChildCode"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/parent_btn_check_child_code" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/parent_link_code_label"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputDeviceVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/parent_hint_verify_code"
                android:inputType="number"
                android:maxLength="6"
                android:minHeight="48dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnSendLinkCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_send_link_code" />

            <Button
                android:id="@+id/btnVerifyDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_verify_device" />

            <Button
                android:id="@+id/btnLinkChildOnLinkStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_link"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCancelAddAnother"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_cancel_add_another"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnCheckServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/parent_btn_check_server"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOpenServerBrowser"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/parent_btn_open_server_browser" />

            <Button
                android:id="@+id/btnAutoLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_auto_link"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- خطوة 4ب: تأكيد الربط -->
        <LinearLayout
            android:id="@+id/stepLinkConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/textLinkVerifiedInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A000000"
                android:padding="12dp"
                android:textIsSelectable="true"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textPendingChildName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/parent_link_code_label"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputLinkConfirmVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/parent_hint_verify_code"
                android:inputType="number"
                android:maxLength="6"
                android:minHeight="48dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnSendLinkCodeConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_send_link_code" />

            <Button
                android:id="@+id/btnLinkChild"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/parent_btn_link" />
        </LinearLayout>

        <include layout="@layout/parent_control_dashboard" />

        <TextView
            android:id="@+id/textParentMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/parent_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/parentBottomNav"
        style="@style/ParentBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:menu="@menu/parent_bottom_nav" />
</LinearLayout>
