<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:layoutDirection="rtl"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <TextView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_step_number"
        android:gravity="center"
        android:text="5"
        android:textColor="@color/parent_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_weight="1"
        android:lineSpacingExtra="2dp"
        android:text="@string/parent_welcome_step_5"
        android:textColor="@color/parent_text_primary"
        android:textSize="14sp" />

    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_step_icon_circle">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_step_accessibility"
            app:tint="@color/parent_primary" />
    </FrameLayout>
</LinearLayout>
