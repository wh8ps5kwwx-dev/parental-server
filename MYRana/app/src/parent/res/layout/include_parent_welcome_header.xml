<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="-16dp"
    android:layout_marginEnd="-16dp"
    android:layout_marginTop="-16dp"
    android:background="@drawable/bg_welcome_header"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBackFromWelcome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_welcome_header_btn"
            android:contentDescription="@string/parent_btn_back_to_control"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_welcome_back"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnWelcomeMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_welcome_header_btn"
            android:contentDescription="@string/parent_btn_view_instructions"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_welcome_menu" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/parent_app_name"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/parent_app_role"
        android:textColor="#E6FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/parent_link_page_title"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="@string/parent_link_page_subtitle"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp" />
</LinearLayout>
