<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/parent_settings_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/parent_settings_retention_hint" />

        <EditText
            android:id="@+id/inputRetentionDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="30"
            android:inputType="number" />

        <CheckBox
            android:id="@+id/checkDailyEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/parent_settings_daily_email" />

        <CheckBox
            android:id="@+id/checkWeeklyEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/parent_settings_weekly_email" />

        <CheckBox
            android:id="@+id/checkAlertSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/parent_settings_alert_sound" />

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/parent_btn_save_settings" />

        <Button
            android:id="@+id/btnSendDailyEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/parent_btn_send_daily_email" />

        <Button
            android:id="@+id/btnSendWeeklyEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/parent_btn_send_weekly_email" />

        <Button
            android:id="@+id/btnLoadAuditLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/parent_btn_load_audit" />

        <TextView
            android:id="@+id/textAuditLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1A000000"
            android:padding="10dp"
            android:textIsSelectable="true"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textSettingsMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
